# Bimo-Nexus runtime token (samme værdi i hele stacken)
NEXUS_TOKEN=dev-token-change-in-production

# GitHub Packages auth — kræves for at host-build kan hente @bimo-dk/nexus-core
# Generer en PAT med read:packages scope: https://github.com/settings/tokens/new
NODE_AUTH_TOKEN=ghp_REPLACE_WITH_YOUR_PAT_WITH_READ_PACKAGES_SCOPE
