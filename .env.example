# Shared secret — skal matche på tværs af alle services
NEXUS_TOKEN=change-this-to-a-strong-secret-in-production

# GitHub Packages — kræves for at bygge images der installerer @bimo-dk/*
NODE_AUTH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS origins (tilføj egne domæner i produktion)
ALLOWED_ORIGINS=http://localhost:8668,http://localhost:8669
