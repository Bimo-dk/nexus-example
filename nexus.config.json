{
  "projectName": "nexusshop",
  "description": "NexusShop — Nexus webshop eksempel med 5 remotes der demonstrerer route-baserede sider, komponent-baseret cross-remote composition og automatisk selvregistrering.",
  "environments": {
    "local": {
      "publicUrl": "http://localhost:8668",
      "registryUrl": "http://localhost:8668/api"
    }
  },
  "dev": {
    "baseEnv": "local",
    "proxyPort": 9000,
    "host": { "mode": "proxy" },
    "remotes": {
      "catalog":  { "port": 8701, "path": "./remote-catalog",  "autostart": false },
      "cart":     { "port": 8702, "path": "./remote-cart",     "autostart": false },
      "product":  { "port": 8703, "path": "./remote-product",  "autostart": false },
      "checkout": { "port": 8704, "path": "./remote-checkout", "autostart": false },
      "account":  { "port": 8705, "path": "./remote-account",  "autostart": false }
    }
  }
}
